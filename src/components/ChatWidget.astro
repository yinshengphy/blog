<div class="chat-widget" data-chat-widget>
  <button class="chat-fab" type="button" aria-label="和我聊聊吧~" data-chat-toggle>
    <svg class="chat-bot-icon" viewBox="0 0 64 64" aria-hidden="true">
      <path class="chat-bot-antenna" d="M32 17V10" />
      <circle class="chat-bot-signal" cx="32" cy="7" r="3.2" />
      <rect class="chat-bot-ear chat-bot-ear-left" x="9" y="31" width="9" height="14" rx="5" />
      <rect class="chat-bot-ear chat-bot-ear-right" x="46" y="31" width="9" height="14" rx="5" />
      <rect class="chat-bot-face" x="15" y="18" width="34" height="35" rx="15" />
      <path class="chat-bot-shine" d="M23 25h12" />
      <circle class="chat-bot-eye chat-bot-eye-left" cx="27" cy="36" r="3.1" />
      <circle class="chat-bot-eye chat-bot-eye-right" cx="38" cy="36" r="3.1" />
      <path class="chat-bot-mouth" d="M28 44c2.4 1.8 5.6 1.8 8 0" />
      <circle class="chat-bot-cheek" cx="23" cy="42" r="2.2" />
      <circle class="chat-bot-cheek" cx="42" cy="42" r="2.2" />
    </svg>
    <span class="chat-fab-tip" aria-hidden="true">和我聊聊吧~</span>
    <span class="chat-spark" aria-hidden="true"></span>
  </button>

  <section class="chat-panel" aria-label="和我聊聊吧" data-chat-panel hidden>
    <header class="chat-panel-head">
      <div>
        <strong>小站助手</strong>
        <span>问文章内容会给引用；普通问题就直接聊</span>
      </div>
      <div class="chat-head-actions">
        <button class="chat-clear" type="button" aria-label="清空当前对话" data-chat-clear>清空</button>
        <button class="chat-close" type="button" aria-label="关闭聊天" data-chat-close>×</button>
      </div>
    </header>

    <div class="chat-messages" data-chat-messages>
      <div class="chat-message bot">
        <div class="chat-bubble bot">嗨，我是小站助手。可以帮你读文章、找观点，也能简单聊点工程问题。</div>
      </div>
      <div class="chat-suggestions" aria-label="建议问题" data-chat-initial-suggestions></div>
    </div>

    <form class="chat-form" data-chat-form>
      <div class="chat-composer-row">
        <textarea data-chat-input name="question" autocomplete="off" maxlength="1200" rows="1" placeholder="输入问题..."></textarea>
        <button type="submit" data-chat-submit>发送</button>
      </div>
    </form>
  </section>
</div>

<script>
  import katex from "katex";

  type SsePayload = any;
  type SseHandlers = Record<string, (data: SsePayload) => void>;
  type StoredMessage = {
    role: "user" | "bot";
    text: string;
    citations?: SsePayload[];
    suggestedQuestions?: string[];
  };
  type ChatState = {
    messages: StoredMessage[];
    open: boolean;
    updatedAt: number;
  };

  const widget = document.querySelector("[data-chat-widget]") as HTMLElement | null;
  const toggle = widget?.querySelector("[data-chat-toggle]") as HTMLButtonElement | null;
  const panel = widget?.querySelector("[data-chat-panel]") as HTMLElement | null;
  const closeButton = widget?.querySelector("[data-chat-close]") as HTMLButtonElement | null;
  const clearButton = widget?.querySelector("[data-chat-clear]") as HTMLButtonElement | null;
  const form = widget?.querySelector("[data-chat-form]") as HTMLFormElement | null;
  const input = widget?.querySelector("[data-chat-input]") as HTMLTextAreaElement | null;
  const submit = widget?.querySelector("[data-chat-submit]") as HTMLButtonElement | null;
  const messages = widget?.querySelector("[data-chat-messages]") as HTMLElement | null;
  let currentController: AbortController | null = null;

  const sessionKey = "yinsheng-chat-session-id-v2";
  const stateKey = "yinsheng-chat-state-v2";
  const stateTtlMs = 2 * 60 * 60 * 1000;
  let sessionId = localStorage.getItem(sessionKey) || crypto.randomUUID();
  localStorage.setItem(sessionKey, sessionId);
  sessionStorage.removeItem("yinsheng-chat-session-id");
  let chatState = loadChatState();

  restoreMessages();
  setOpen(chatState.open, false);

  function setOpen(open: boolean, persist = true) {
    if (!panel || !toggle) return;
    panel.hidden = !open;
    toggle.setAttribute("aria-expanded", String(open));
    chatState.open = open;
    if (persist) saveChatState();
    if (open) input?.focus();
  }

  history.replaceState({ yinshengSoftNav: true }, "", window.location.href);

  toggle?.addEventListener("click", () => setOpen(panel?.hidden ?? true));
  closeButton?.addEventListener("click", () => setOpen(false));
  clearButton?.addEventListener("click", clearConversation);

  messages?.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    const link = target.closest<HTMLAnchorElement>("a[data-chat-cite-link]");
    if (!link) return;

    const url = new URL(link.href, window.location.href);
    if (url.origin !== window.location.origin) return;

    event.preventDefault();
    await navigateInPlace(url, true, link.dataset.chatCiteSnippet || "");
  });

  window.addEventListener("popstate", () => {
    navigateInPlace(new URL(window.location.href), false);
  });

  messages?.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;
    const button = target.closest<HTMLButtonElement>("button[data-suggestion]");
    if (!button || !(input instanceof HTMLTextAreaElement)) return;
    const questionText = button.dataset.suggestion || "";
    if (!questionText) return;
    input.value = questionText;
    form?.requestSubmit();
  });

  input?.addEventListener("keydown", (event) => {
    if (event.key !== "Enter" || event.isComposing) return;
    if (event.altKey) return;
    event.preventDefault();
    form?.requestSubmit();
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(input instanceof HTMLTextAreaElement) || !(submit instanceof HTMLButtonElement)) return;

    if (currentController) {
      currentController.abort();
      currentController = null;
      submit.textContent = "发送";
      input.disabled = false;
      input.focus();
      return;
    }

    const question = input.value.trim();
    if (!question) return;

    messages?.querySelectorAll(".chat-suggestions").forEach((element) => element.remove());
    const requestHistory = chatState.messages.slice(-8).map((message) => ({
      role: message.role === "bot" ? "assistant" : "user",
      content: message.text
    }));
    appendBubble("user", question);
    rememberMessage({ role: "user", text: question });
    input.value = "";
    input.disabled = true;
    submit.textContent = "停止";
    currentController = new AbortController();

    const answerBubble = appendBubble("bot streaming", "");
    const answerText = document.createElement("span");
    answerText.className = "chat-answer-text";
    answerBubble.append(answerText);
    let rawAnswer = "";
    let latestCitations: SsePayload[] = [];
    let latestSuggestedQuestions: string[] = [];
    let answerStored = false;

    try {
      const response = await fetch("/api/chat/stream", {
        method: "POST",
        headers: { "Content-Type": "application/json", "Accept": "text/event-stream" },
        body: JSON.stringify({
          question,
          sessionId,
          pageContext: currentPageContext(),
          history: requestHistory
        }),
        signal: currentController.signal
      });
      if (!response.ok || !response.body) throw new Error("stream failed");
      await readSse(response.body, {
        delta(data) {
          rawAnswer += data.text || "";
          answerText.textContent = rawAnswer;
          scrollMessages();
        },
        citations(data) {
          latestCitations = Array.isArray(data) ? data : [];
          answerBubble.classList.remove("streaming");
          renderAnswerContent(answerText, rawAnswer, latestCitations);
        },
        suggestedQuestions(data) {
          latestSuggestedQuestions = Array.isArray(data)
            ? data.filter((value) => typeof value === "string").slice(0, 3)
            : [];
        },
        error(data) {
          answerBubble.classList.remove("streaming");
          rawAnswer = data.message || "聊天服务暂时不可用，请稍后再试。";
          answerText.textContent = rawAnswer;
          rememberMessage({ role: "bot", text: rawAnswer });
          answerStored = true;
        },
        done(data) {
          if (typeof data.answer === "string" && data.answer) rawAnswer = data.answer;
          answerBubble.classList.remove("streaming");
          renderAnswerContent(answerText, rawAnswer, latestCitations);
          appendSuggestionRow(latestSuggestedQuestions);
          rememberMessage({
            role: "bot",
            text: rawAnswer,
            citations: latestCitations,
            suggestedQuestions: latestSuggestedQuestions
          });
          answerStored = true;
        }
      });
    } catch (error) {
      answerBubble.classList.remove("streaming");
      rawAnswer = error instanceof DOMException && error.name === "AbortError"
        ? "已停止生成。"
        : "聊天服务暂时不可用，请稍后再试。";
      answerText.textContent = rawAnswer;
      if (!answerStored) rememberMessage({ role: "bot", text: rawAnswer });
    } finally {
      currentController = null;
      input.disabled = false;
      submit.textContent = "发送";
      input.focus();
    }
  });

  function loadChatState(): ChatState {
    try {
      const value = localStorage.getItem(stateKey);
      if (!value) return { messages: [], open: false, updatedAt: Date.now() };
      const parsed = JSON.parse(value) as ChatState;
      if (!Array.isArray(parsed.messages) || Date.now() - Number(parsed.updatedAt || 0) > stateTtlMs) {
        localStorage.removeItem(stateKey);
        return { messages: [], open: false, updatedAt: Date.now() };
      }
      return {
        messages: parsed.messages.slice(-20),
        open: Boolean(parsed.open),
        updatedAt: Number(parsed.updatedAt || Date.now())
      };
    } catch {
      localStorage.removeItem(stateKey);
      return { messages: [], open: false, updatedAt: Date.now() };
    }
  }

  function saveChatState() {
    chatState.messages = chatState.messages.slice(-20);
    chatState.updatedAt = Date.now();
    localStorage.setItem(stateKey, JSON.stringify(chatState));
  }

  function rememberMessage(message: StoredMessage) {
    if (!message.text.trim()) return;
    chatState.messages.push({
      ...message,
      text: message.text.slice(0, 4000),
      citations: message.citations?.slice(0, 3),
      suggestedQuestions: message.suggestedQuestions?.slice(0, 3)
    });
    saveChatState();
  }

  function restoreMessages() {
    if (!messages) return;
    if (chatState.messages.length === 0) {
      renderInitialSuggestions();
      return;
    }
    messages.replaceChildren();
    chatState.messages.forEach((message, index) => {
      const bubble = appendBubble(message.role, "");
      if (message.role === "bot") {
        const answer = document.createElement("span");
        answer.className = "chat-answer-text";
        bubble.append(answer);
        renderAnswerContent(answer, message.text, message.citations || []);
        if (index === chatState.messages.length - 1) {
          appendSuggestionRow(message.suggestedQuestions || []);
        }
      } else {
        bubble.append(document.createTextNode(message.text));
      }
    });
  }

  function clearConversation() {
    currentController?.abort();
    currentController = null;
    sessionId = crypto.randomUUID();
    localStorage.setItem(sessionKey, sessionId);
    chatState = { messages: [], open: true, updatedAt: Date.now() };
    saveChatState();
    if (!messages) return;
    messages.replaceChildren();
    const bubble = appendBubble("bot", "嗨，我是小站助手。可以帮你理解文章、定位章节，也能聊技术问题。");
    bubble.closest(".chat-message")?.setAttribute("data-chat-greeting", "true");
    renderInitialSuggestions();
    input?.focus();
  }

  function renderInitialSuggestions() {
    const container = messages?.querySelector<HTMLElement>("[data-chat-initial-suggestions]");
    const suggestions = initialSuggestions();
    if (container) {
      fillSuggestionButtons(container, suggestions);
      return;
    }
    appendSuggestionRow(suggestions, true);
  }

  function initialSuggestions() {
    if (currentPageContext().pageType === "BLOG_POST") {
      return ["总结这篇文章", "这篇文章的核心观点是什么？", "这篇文章还有哪些相关内容？"];
    }
    return ["这个博客主要写了哪些内容？", "推荐几篇关于 RAG 与系统架构的文章", "你能帮我做什么？"];
  }

  function appendSuggestionRow(values: string[], initial = false) {
    if (!messages || values.length === 0) return;
    const row = document.createElement("div");
    row.className = "chat-suggestions";
    row.setAttribute("aria-label", initial ? "建议问题" : "可以继续问");
    if (initial) row.dataset.chatInitialSuggestions = "true";
    fillSuggestionButtons(row, values);
    messages.append(row);
    scrollMessages();
  }

  function fillSuggestionButtons(container: HTMLElement, values: string[]) {
    container.replaceChildren(...values.slice(0, 3).map((value) => {
      const button = document.createElement("button");
      button.type = "button";
      button.dataset.suggestion = value;
      button.textContent = value;
      return button;
    }));
  }

  function appendBubble(kind: string, text: string) {
    const role = kind.includes("user") ? "user" : "bot";
    const row = document.createElement("div");
    row.className = `chat-message ${role}`;

    const bubble = document.createElement("div");
    bubble.className = `chat-bubble ${kind}`;
    if (text) bubble.append(document.createTextNode(text));

    row.append(bubble);
    messages?.append(row);
    scrollMessages();
    return bubble;
  }

  function currentPageContext() {
    const article = document.querySelector<HTMLElement>("article.post-shell");
    if (!article) return { pageType: "HOME", url: location.pathname };
    const slug = decodeURIComponent(location.pathname.replace(/^\/+|\/+$/g, ""));
    const title = article.querySelector("h1")?.textContent?.trim() || document.title;
    const hashHeading = location.hash ? document.getElementById(decodeURIComponent(location.hash.slice(1)))?.textContent?.trim() : "";
    return { pageType: "BLOG_POST", slug, title, url: location.pathname, heading: hashHeading || "" };
  }

  function renderAnswerContent(container: HTMLElement, rawText: string, citations: SsePayload[]) {
    if (!rawText) return;
    const byIndex = new Map<number, SsePayload>();
    const fragment = document.createDocumentFragment();
    const state = { matchedCitation: false };
    if (Array.isArray(citations)) {
      citations.slice(0, 3).forEach((citation, index) => byIndex.set(index + 1, citation));
    }

    appendRichText(fragment, rawText, byIndex, state);

    if (!state.matchedCitation && Array.isArray(citations) && citations.length > 0) {
      const sources = document.createElement("div");
      sources.className = "chat-source-list";
      const label = document.createElement("strong");
      label.textContent = "参考来源";
      sources.append(label);
      citations.slice(0, 3).forEach((citation, index) => {
        const link = citationAnchor(citation);
        link.textContent = `${index + 1}. ${citation.title || citation.section || "来源"}`;
        sources.append(link);
      });
      fragment.append(sources);
    }

    container.replaceChildren(fragment);
  }

  function appendRichText(
    fragment: DocumentFragment | HTMLElement,
    text: string,
    citations: Map<number, SsePayload>,
    state: { matchedCitation: boolean }
  ) {
    const tokenPattern = /```(?:math|latex)\s*([\s\S]+?)```|\$\$([\s\S]+?)\$\$|\\\[([\s\S]+?)\\\]|\\\(([\s\S]+?)\\\)|\$([^$\n]+)\$|\[(\d+)\]/g;
    let cursor = 0;
    let match: RegExpExecArray | null;
    const citationSeqMap = new Map<number, number>();
    let seqCounter = 0;

    while ((match = tokenPattern.exec(text)) !== null) {
      appendMarkdownText(fragment, text.slice(cursor, match.index));
      if (match[1] || match[2] || match[3]) {
        fragment.append(katexNode((match[1] || match[2] || match[3] || "").trim(), true));
      } else if (match[4] || match[5]) {
        fragment.append(katexNode((match[4] || match[5] || "").trim(), false));
      } else if (match[6]) {
        const rawIndex = Number(match[6]);
        const citation = citations.get(rawIndex);
        if (citation) {
          let seq = citationSeqMap.get(rawIndex);
          if (!seq) {
            seqCounter += 1;
            seq = seqCounter;
            citationSeqMap.set(rawIndex, seq);
          }
          fragment.append(citationLink(seq, citation));
          state.matchedCitation = true;
        }
      }
      cursor = match.index + match[0].length;
    }
    appendMarkdownText(fragment, text.slice(cursor));
  }

  function appendMarkdownText(fragment: DocumentFragment | HTMLElement, text: string) {
    if (!text) return;
    const lines = text.split("\n");
    lines.forEach((line, index) => {
      if (index > 0) fragment.append(document.createElement("br"));
      appendInlineMarkdown(fragment, line);
    });
  }

  function appendInlineMarkdown(fragment: DocumentFragment | HTMLElement, text: string) {
    const inlinePattern = /`([^`]+)`|\*\*([^*]+)\*\*/g;
    let cursor = 0;
    let match: RegExpExecArray | null;
    while ((match = inlinePattern.exec(text)) !== null) {
      fragment.append(document.createTextNode(text.slice(cursor, match.index)));
      if (match[1]) {
        const code = document.createElement("code");
        code.textContent = match[1];
        fragment.append(code);
      } else if (match[2]) {
        const strong = document.createElement("strong");
        strong.textContent = match[2];
        fragment.append(strong);
      }
      cursor = match.index + match[0].length;
    }
    fragment.append(document.createTextNode(text.slice(cursor)));
  }

  function katexNode(expression: string, displayMode: boolean) {
    const node = document.createElement(displayMode ? "div" : "span");
    node.className = displayMode ? "chat-math-display" : "chat-math-inline";
    try {
      node.innerHTML = katex.renderToString(expression, {
        displayMode,
        throwOnError: false,
        strict: "ignore"
      });
    } catch {
      node.textContent = displayMode ? `$$${expression}$$` : `$${expression}$`;
    }
    return node;
  }

  function citationLink(index: number, citation: SsePayload) {
    const sup = document.createElement("sup");
    sup.className = "chat-cite-ref";
    const link = citationAnchor(citation);
    link.textContent = String(index);
    sup.append(link);
    return sup;
  }

  function citationAnchor(citation: SsePayload) {
    const link = document.createElement("a");
    link.href = citation.url || "#";
    link.title = [citation.title, citation.section].filter(Boolean).join(" · ");
    link.dataset.chatCiteLink = "true";
    link.dataset.chatCiteSnippet = citation.snippet || "";
    try {
      if (new URL(link.href, window.location.href).origin !== window.location.origin) {
        link.target = "_blank";
        link.rel = "noreferrer";
      }
    } catch {
      // 无效链接保持普通文本行为。
    }
    return link;
  }

  async function navigateInPlace(url: URL, push = true, snippet = "") {
    try {
      if (isSamePage(url)) {
        if (push) history.pushState({ yinshengSoftNav: true }, "", url.href);
        scrollToHash(url.hash, snippet);
        return;
      }

      const response = await fetch(url.pathname + url.search, {
        headers: { "Accept": "text/html" }
      });
      if (!response.ok) throw new Error("navigation failed");

      const html = await response.text();
      const nextDocument = new DOMParser().parseFromString(html, "text/html");
      const nextMain = nextDocument.querySelector("main");
      const currentMain = document.querySelector("main");
      if (!nextMain || !currentMain) throw new Error("main not found");

      currentMain.replaceChildren(
        ...Array.from(nextMain.childNodes).map((node) => document.importNode(node, true))
      );
      document.title = nextDocument.title;
      updateMetaDescription(nextDocument);

      if (push) history.pushState({ yinshengSoftNav: true }, "", url.href);
      scrollToHash(url.hash, snippet);
      setOpen(true);
    } catch {
      window.location.href = url.href;
    }
  }

  function isSamePage(url: URL) {
    return url.pathname === window.location.pathname && url.search === window.location.search;
  }

  function scrollToHash(hash: string, snippet = "") {
    requestAnimationFrame(() => {
      if (!hash) {
        window.scrollTo({ top: 0, behavior: "smooth" });
        return;
      }

      const target = document.getElementById(decodeURIComponent(hash.slice(1)));
      if (target) {
        const preciseTarget = findSnippetTarget(target, snippet) || target;
        preciseTarget.scrollIntoView({ block: "center", behavior: "smooth" });
        highlightCitationTarget(preciseTarget);
      }
    });
  }

  function findSnippetTarget(anchor: HTMLElement, snippet: string) {
    const normalizedSnippet = normalizeText(snippet);
    if (!normalizedSnippet || normalizedSnippet.length < 8) return null;
    const candidates = citationCandidates(anchor);
    let best: HTMLElement | null = null;
    let bestScore = 0;
    candidates.forEach((candidate) => {
      const text = normalizeText(candidate.textContent || "");
      if (!text) return;
      let score = text.includes(normalizedSnippet.slice(0, Math.min(60, normalizedSnippet.length))) ? 1000 : 0;
      citationTerms(normalizedSnippet).forEach((term) => {
        if (text.includes(term)) score += Math.max(1, term.length - 1);
      });
      if (score > bestScore) {
        best = candidate;
        bestScore = score;
      }
    });
    return bestScore > 0 ? best : null;
  }

  function citationCandidates(anchor: HTMLElement) {
    const candidates: HTMLElement[] = [];
    const prose = document.querySelector<HTMLElement>(".prose");
    const anchorLevel = headingLevel(anchor);
    if (!prose?.contains(anchor)) {
      for (const child of Array.from(prose?.children || [])) {
        if (isHeading(child)) break;
        collectReadableBlocks(child, candidates);
      }
      return candidates;
    }

    let current = anchor.nextElementSibling;
    while (current) {
      if (isHeading(current) && headingLevel(current as HTMLElement) <= anchorLevel) break;
      collectReadableBlocks(current, candidates);
      current = current.nextElementSibling;
    }
    return candidates;
  }

  function collectReadableBlocks(element: Element, candidates: HTMLElement[]) {
    if (!(element instanceof HTMLElement)) return;
    if (element.matches("p, li, blockquote, pre, table")) {
      candidates.push(element);
      return;
    }
    element.querySelectorAll<HTMLElement>("p, li, blockquote, pre, table").forEach((child) => candidates.push(child));
  }

  function isHeading(element: Element) {
    return /^H[1-6]$/.test(element.tagName);
  }

  function headingLevel(element: HTMLElement) {
    return isHeading(element) ? Number(element.tagName.slice(1)) : 1;
  }

  function citationTerms(normalized: string) {
    const terms = new Set<string>();
    const latin = normalized.match(/[a-z0-9]{2,}/g) || [];
    latin.forEach((term) => terms.add(term));
    const han = normalized.match(/[\p{Script=Han}]{2,}/gu) || [];
    han.forEach((text) => {
      for (let index = 0; index < text.length - 1; index += 1) {
        terms.add(text.slice(index, index + 2));
      }
    });
    return Array.from(terms).filter((term) => !["这个", "一种", "可以", "通过", "实现", "问题", "内容", "文章"].includes(term));
  }

  function normalizeText(value: string) {
    return value
      .toLowerCase()
      .normalize("NFKC")
      .replace(/[`*_~[\](){}<>"'，。！？；：、,.!?\s-]/g, "");
  }

  function highlightCitationTarget(target: HTMLElement) {
    document.querySelectorAll(".chat-citation-focus").forEach((element) => {
      element.classList.remove("chat-citation-focus");
    });
    target.classList.add("chat-citation-focus");
    window.setTimeout(() => target.classList.remove("chat-citation-focus"), 2200);
  }

  function updateMetaDescription(nextDocument: Document) {
    const current = document.querySelector<HTMLMetaElement>('meta[name="description"]');
    const next = nextDocument.querySelector<HTMLMetaElement>('meta[name="description"]');
    if (current && next?.content) current.content = next.content;
  }

  async function readSse(stream: ReadableStream<Uint8Array>, handlers: SseHandlers) {
    const reader = stream.getReader();
    const decoder = new TextDecoder();
    let buffer = "";
    while (true) {
      const { value, done } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      const events = buffer.split("\n\n");
      buffer = events.pop() || "";
      events.forEach((eventBlock) => dispatchSse(eventBlock, handlers));
    }
    if (buffer.trim()) dispatchSse(buffer, handlers);
  }

  function dispatchSse(block: string, handlers: SseHandlers) {
    const lines = block.split("\n");
    const event = lines.find((line: string) => line.startsWith("event:"))?.slice(6).trim() || "message";
    const dataText = lines.filter((line: string) => line.startsWith("data:")).map((line: string) => line.slice(5).trim()).join("\n");
    let data = {};
    try {
      data = dataText ? JSON.parse(dataText) : {};
    } catch {
      data = { text: dataText };
    }
    handlers[event]?.(data);
  }

  function scrollMessages() {
    if (messages) messages.scrollTop = messages.scrollHeight;
  }

</script>

