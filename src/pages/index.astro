---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const categories = ['技术学习', '知识笔记', '生活碎念'];
const latestDate = posts[0]?.data.date;

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  });
}
---

<BaseLayout title="yinsheng的小站" description="记录技术实践、知识笔记与项目复盘的个人博客。">
  <div class="home-page">
    <header class="home-heading">
      <h1>记录技术原理、工程实践与项目复盘。</h1>
      <p>这里是 yinsheng 的个人技术博客，记录学习新知识时的推演、项目实践和一些生活片段。</p>
      {latestDate && (
        <p class="home-updated">最后更新：<time datetime={latestDate.toISOString()}>{formatDate(latestDate)}</time></p>
      )}
    </header>

    <section class="article-index" id="articles" aria-labelledby="articles-title">
      <h2 class="sr-only" id="articles-title">全部文章</h2>
      <div class="category-nav" role="tablist" aria-label="文章分类">
        <button class="is-active" type="button" role="tab" aria-selected="true" data-category="全部文章">
          全部文章 <span>{posts.length}</span>
        </button>
        {categories.map((category) => (
          <button type="button" role="tab" aria-selected="false" data-category={category}>
            {category}
            <span>{posts.filter((post) => post.data.categories.includes(category)).length}</span>
          </button>
        ))}
      </div>

      <div class="article-list" aria-live="polite">
      {posts.map((post) => (
        <article class="article-list-item" data-categories={post.data.categories.join(',')}>
          <div class="article-list-header">
            <h3><a href={`/${post.id}/`}>{post.data.title}</a></h3>
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
          </div>
          <div class="article-taxonomy">
            {post.data.categories[0] && (
              <a class="category-link" href={`/categories/${encodeURIComponent(post.data.categories[0])}/`}>
                {post.data.categories[0]}
              </a>
            )}
            {post.data.tags.map((tag) => (
              <a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
            ))}
          </div>
          <p>{post.data.description}</p>
          <a class="article-read-link" href={`/${post.id}/`}>阅读全文</a>
        </article>
      ))}
      </div>
      <div class="article-filter-empty" hidden>
        <h3>这里还没有文章</h3>
        <p>以后随手记录的生活片段，会放在这里。</p>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const tabs = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.category-nav [role="tab"]')
  );
  const articles = Array.from(
    document.querySelectorAll<HTMLElement>('.article-list-item')
  );
  const emptyState = document.querySelector<HTMLElement>('.article-filter-empty');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const category = tab.dataset.category || '全部文章';
      let visibleCount = 0;

      tabs.forEach((item) => {
        const isSelected = item === tab;
        item.classList.toggle('is-active', isSelected);
        item.setAttribute('aria-selected', String(isSelected));
      });

      articles.forEach((article) => {
        const categories = (article.dataset.categories || '').split(',');
        const isVisible = category === '全部文章' || categories.includes(category);
        article.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }
    });
  });
</script>
